# Sub-repos (managed separately, cloned via syncing-repos skill)
repos/*
!repos/repos.json.example

# Git worktrees (created per parallel worker by epic workflow)
trees/

# Temporary agent work files
.tmp/

# Plan draft transient files
plans/drafts/*.tmp
plans/drafts/*.swp
plans/drafts/*.swo

# Local-only: which plan the session is actively discussing (plan review auto-follow)
plans/session-context.json

# Beads runtime files (Dolt backend)
.beads/*.db
.beads/*.db-wal
.beads/*.db-shm
.beads/.daemon*
.beads/.dolt/
.beads/issues.jsonl
# Per-clone Beads identity — must NOT be shared across users.
# Each clone regenerates its own project_id via `bd init` / `bd doctor --fix`.
.beads/metadata.json

# Dashboard generated data
docs/data/beads.json

# Vite production build output (dashboard root is docs/)
docs/dist/

# Standard
node_modules/
.env
.env.local
.idea/
.vscode/
*.DS_Store

# Playwright MCP artifacts
.playwright-mcp/

# Bun lockfile (commit this if you want reproducible installs)
# bun.lockb

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
