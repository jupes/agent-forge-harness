{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "types": ["bun-types"],
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@/types/*": ["./types/*"],
      "@docs/skill-builder": ["./docs/js/skill-builder.mjs"],
      "@docs/bead-builder": ["./docs/js/bead-builder.mjs"]
    }
  },
  "include": [
    "scripts/**/*.ts",
    ".claude/hooks/**/*.ts",
    ".claude/skills/**/*.ts",
    "types/**/*.ts",
    "docs/js/**/*.tsx",
    "docs/js/**/*.ts",
    "docs/js/**/*.d.mts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "trees",
    "repos"
  ]
}
