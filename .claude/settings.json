{
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime 2>/dev/null || true",
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-dangerous-git.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd dolt start 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bd prime 2>/dev/null || true",
            "type": "command"
          },
          {
            "command": "bun run agents-md validate --hook",
            "type": "command"
          },
          {
            "command": "bun run .claude/hooks/session.ts",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bun run .claude/hooks/forge-phase-gate.ts --stop-hook",
            "type": "command"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "command": "bun run .claude/hooks/quality-gate.ts",
            "type": "command"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "command": "bun run .claude/hooks/quality-gate.ts",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "bun *",
      "git status",
      "git diff",
      "git log",
      "git branch",
      "git checkout",
      "git add",
      "git commit",
      "git pull",
      "git push",
      "git merge",
      "git rebase",
      "git stash",
      "git worktree",
      "git fetch",
      "gh pr *",
      "gh issue *",
      "gh repo *",
      "gh api *",
      "bd dolt pull",
      "bd dolt push",
      "bd dolt start",
      "bd dolt status",
      "bd ready",
      "bd show",
      "bd list",
      "bd close",
      "bd create",
      "bd comments",
      "bd update",
      "bd dep",
      "bd doctor",
      "bd prime",
      "grep *",
      "jq *",
      "wc *",
      "ls *",
      "find *",
      "cat *",
      "head *",
      "tail *"
    ],
    "deny": [
      "rm -rf *",
      "git push --force",
      "git push -f",
      "git clean -fdx",
      "npm publish",
      "bun publish",
      "bd doctor --fix",
      "bd config"
    ]
  },
  "teammate": {
    "mode": "tmux"
  }
}
