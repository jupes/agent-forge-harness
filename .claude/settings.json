{
  "env": {
    "CLAUDE_CODE_DISABLE_AUTO_MEMORY": "0",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime 2\u003e/dev/null || true",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime 2\u003e/dev/null || true",
            "type": "command"
          },
          {
            "command": "bun run agents-md validate --hook",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "command": "bun run .claude/hooks/quality-gate.ts",
            "type": "command"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "command": "bun run .claude/hooks/quality-gate.ts",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "bun *",
      "git status",
      "git diff",
      "git log",
      "git branch",
      "git checkout",
      "git add",
      "git commit",
      "git pull",
      "git push",
      "git merge",
      "git rebase",
      "git stash",
      "git worktree",
      "git fetch",
      "gh pr *",
      "gh issue *",
      "gh repo *",
      "gh api *",
      "bd dolt pull",
      "bd ready",
      "bd show",
      "bd close",
      "bd create",
      "bd comments",
      "bd update",
      "bd dep",
      "bd doctor",
      "bd prime",
      "bd dolt push",
      "grep *",
      "jq *",
      "wc *",
      "ls *",
      "find *",
      "cat *",
      "head *",
      "tail *"
    ],
    "deny": [
      "rm -rf *",
      "git push --force",
      "git push -f",
      "git clean -fdx",
      "npm publish",
      "bun publish",
      "bd doctor --fix",
      "bd config"
    ]
  },
  "teammate": {
    "mode": "tmux"
  }
}