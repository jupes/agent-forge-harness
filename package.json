{
  "name": "agent-forge-harness",
  "version": "0.1.0",
  "description": "Composable agentic coding system for development teams using Claude Code",
  "private": true,
  "scripts": {
    "setup": "bun run scripts/setup.ts",
    "build-pages": "bun run scripts/build-pages.ts",
    "dashboard": "vite --config vite.dashboard.config.ts",
    "worktree": "bun run scripts/worktree.ts",
    "repo": "bun run .claude/skills/syncing-repos/scripts/repo.ts",
    "test": "bun test scripts",
    "quality-gate": "bun run .claude/hooks/quality-gate.ts",
    "beads:import-anthropic-plan": "bun run scripts/beads/import-anthropic-harness-plan.ts",
    "tmp:cleanup": "bun run scripts/tmp-work-cleanup.ts",
    "beads:bundles": "bun run scripts/beads/convoy-bundles.ts",
    "agents-md": "bun run scripts/agents-md.ts",
    "molecules:check": "bun run scripts/molecules/check.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check scripts .claude/hooks .claude/skills types docs/js",
    "lint:fix": "biome check --write scripts .claude/hooks .claude/skills types docs/js"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@preact/preset-vite": "^2.10.5",
    "@types/bun": "latest",
    "chokidar": "^4.0.3",
    "vite": "^6.3.5"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "chart.js": "4.4.7",
    "chartjs-chart-matrix": "2.0.1",
    "preact": "^10.29.1"
  }
}
